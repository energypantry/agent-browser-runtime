# Host-facing ports are bound to 127.0.0.1 only.
BROKER_HOST_PORT=17890
CDP_HOST_PORT=19223
NOVNC_HOST_PORT=16080

# Runtime browser defaults
SCREEN_WIDTH=1440
SCREEN_HEIGHT=1000
SCREEN_DEPTH=24
FINGERPRINT_SEED=1000
FINGERPRINT_PLATFORM=macos
BROWSER_TIMEZONE=Asia/Shanghai
BOT_HUMANIZE_LEVEL=enhanced
BOT_RUNTIME_SIGNATURE=browser-runtime-skill:v3-stealth-policy|chrome=compose|profile=/data/user-data

# Default browser consistency policy. Enabled by default for all regular http/https tabs.
BRS_STEALTH_ENABLED=1
BRS_STEALTH_PROFILE=standard
BRS_FINGERPRINT_HEADERS_ENABLED=1
BRS_FINGERPRINT_PATCHES_ENABLED=1
BRS_CANVAS_NOISE_ENABLED=1
BRS_AUDIO_NOISE_ENABLED=1
BRS_ACCEPT_LANGUAGE=en-US,en;q=0.9
BRS_LOCALE=en-US
BRS_STEALTH_TIMEZONE=
BRS_USER_AGENT=
BRS_PLATFORM=
BRS_WEBGL_VENDOR=
BRS_WEBGL_RENDERER=
BRS_EXTRA_HTTP_HEADERS_JSON=

# Optional proxy/TLS gateway integration. The gateway is default-enabled as a
# capability, but only becomes active when BRS_TLS_GATEWAY_PROXY_SERVER is set.
# BROWSER_PROXY_SERVER=http://proxy:8080
BROWSER_PROXY_BYPASS_LIST=127.0.0.1,localhost,::1,broker,chrome-runtime
BRS_TLS_GATEWAY_ENABLED=1
BRS_TLS_GATEWAY_PROXY_SERVER=

# Internal broker WS consumed by the companion extension. Keep this at 17890 unless
# extension/background.js and docker-compose.yml are updated together.
BROWSER_RUNTIME_BROKER_WS=ws://broker:17890/extension
